HELIOS_ENV=development
HELIOS_LOG_LEVEL=info
HELIOS_CONFIG_HOME=~/.config/helios

# Local agent defaults
HELIOS_AGENT_ID=local-dev
HELIOS_HOTWORD=Hey Helios
HELIOS_STT_PROVIDER=stub
HELIOS_TTS_PROVIDER=stub
HELIOS_ALLOW_SHELL=false
HELIOS_CONTROL_PLANE_URL=http://localhost:8080

# Optional SaaS control plane
HELIOS_DATABASE_URL=postgresql://helios:helios@postgres:5432/helios
HELIOS_REDIS_URL=redis://redis:6379/0
HELIOS_JWT_SECRET=replace-me
HELIOS_SIGNING_KEY=dev-only-signing-key
