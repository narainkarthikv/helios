# ============================================
# Backend Configuration
# ============================================
NODE_ENV=development
BACKEND_PORT=5000
JWT_SECRET=your-secret-key-here-change-this-in-production
JWT_EXPIRATION=7d

# ============================================
# MongoDB Configuration
# ============================================
# Local MongoDB
MONGODB_URI=mongodb://admin:password@mongodb:27017/glis?authSource=admin

# OR MongoDB Atlas (comment out local MongoDB and use this instead)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/glis?retryWrites=true&w=majority

# Docker MongoDB Root Credentials
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=password

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:5000/
VITE_APININJAS=your-api-ninjas-key-here

# ============================================
# Application
# ============================================
REACT_APP_ENV=development
