FROM python:3.12-slim

WORKDIR /app
ENV PYTHONPATH=/app/packages/helios-core/src:/app/services/control-plane/src

COPY packages/helios-core /app/packages/helios-core
COPY services/control-plane /app/services/control-plane

RUN pip install --no-cache-dir fastapi uvicorn

EXPOSE 8080
CMD ["uvicorn", "helios_control_plane.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8080"]
